<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SCP Foundation — RH Site-55</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;500;600;700&family=Teko:wght@300;400;500;600&display=swap');

:root {
  --bg:#080b0f; --bg2:#0d1117; --bg3:#111820; --surface:#141c25;
  --border:#1e2d3d; --border2:#243344;
  --accent:#ff6b00; --red:#c0392b; --green:#00c853; --yellow:#ffd600; --cyan:#4fc3f7;
  --text:#c8d6e5; --text2:#7a9ab5; --text3:#3d5a73; --white:#e8f0f8;
  --scan:rgba(255,107,0,0.025);
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Rajdhani',sans-serif;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,var(--scan) 2px,var(--scan) 4px);pointer-events:none;z-index:1000;animation:scanmove 8s linear infinite;}
@keyframes scanmove{0%{background-position:0 0}100%{background-position:0 100px}}
body::after{content:'';position:fixed;inset:0;opacity:.02;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");pointer-events:none;z-index:999;}
::-webkit-scrollbar{width:4px;height:4px}::-webkit-scrollbar-track{background:var(--bg2)}::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

/* ── LOGIN SCREEN ── */
#login-screen{position:fixed;inset:0;background:var(--bg);z-index:9000;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2rem;}
#login-screen.hidden{display:none;}
.login-logo svg{width:72px;height:72px;filter:drop-shadow(0 0 20px var(--accent));animation:logopulse 3s ease-in-out infinite;}
.login-box{background:var(--bg2);border:1px solid var(--border2);width:380px;padding:0;}
.login-box-header{background:var(--bg3);border-bottom:1px solid var(--border);padding:1.2rem 1.6rem;text-align:center;}
.login-box-header .title{font-family:'Teko',sans-serif;font-size:1.4rem;letter-spacing:.15em;color:var(--white);text-transform:uppercase;}
.login-box-header .sub{font-family:'Share Tech Mono',monospace;font-size:.6rem;color:var(--accent);letter-spacing:.15em;text-transform:uppercase;margin-top:3px;}
.login-box-body{padding:1.6rem;}
.login-field{display:flex;flex-direction:column;gap:5px;margin-bottom:1rem;}
.login-field label{font-family:'Share Tech Mono',monospace;font-size:.58rem;letter-spacing:.15em;color:var(--text3);text-transform:uppercase;}
.login-field input{background:var(--bg);border:1px solid var(--border2);color:var(--white);font-family:'Share Tech Mono',monospace;font-size:.85rem;padding:10px 14px;outline:none;width:100%;letter-spacing:.08em;transition:border-color .15s;}
.login-field input:focus{border-color:var(--accent);box-shadow:0 0 0 2px rgba(255,107,0,.1);}
.login-btn{width:100%;background:rgba(255,107,0,.08);border:1px solid var(--accent);color:var(--accent);font-family:'Share Tech Mono',monospace;font-size:.7rem;letter-spacing:.15em;padding:12px;cursor:pointer;text-transform:uppercase;transition:all .15s;margin-top:.4rem;}
.login-btn:hover{background:var(--accent);color:#000;box-shadow:0 0 24px rgba(255,107,0,.4);}
.login-error{font-family:'Share Tech Mono',monospace;font-size:.65rem;color:var(--red);text-align:center;padding:.5rem;border:1px solid rgba(192,57,43,.3);background:rgba(192,57,43,.07);display:none;letter-spacing:.08em;margin-top:.8rem;}
.login-error.show{display:block;}
.login-hint{font-family:'Share Tech Mono',monospace;font-size:.55rem;color:var(--text3);text-align:center;letter-spacing:.1em;padding:.6rem 1.6rem 1.4rem;}

/* ── HEADER ── */
header{background:linear-gradient(180deg,#0a0f15,var(--bg2));border-bottom:1px solid var(--border2);padding:0 2rem;position:sticky;top:0;z-index:100;display:flex;align-items:center;justify-content:space-between;height:64px;}
.header-left{display:flex;align-items:center;gap:1.2rem;}
.scp-logo svg{width:42px;height:42px;filter:drop-shadow(0 0 6px var(--accent));animation:logopulse 3s ease-in-out infinite;}
@keyframes logopulse{0%,100%{filter:drop-shadow(0 0 4px var(--accent))}50%{filter:drop-shadow(0 0 14px var(--accent))}}
.header-title .main{font-family:'Teko',sans-serif;font-size:1.5rem;font-weight:600;letter-spacing:.15em;color:var(--white);text-transform:uppercase;}
.header-title .sub{font-family:'Share Tech Mono',monospace;font-size:.62rem;color:var(--accent);letter-spacing:.12em;text-transform:uppercase;}
.header-right{display:flex;align-items:center;gap:1.2rem;}
.clearance-badge{font-family:'Share Tech Mono',monospace;font-size:.65rem;letter-spacing:.1em;padding:4px 10px;border:1px solid var(--accent);color:var(--accent);background:rgba(255,107,0,.07);text-transform:uppercase;}
.clearance-badge.admin-badge{border-color:var(--red);color:var(--red);background:rgba(192,57,43,.1);}
.status-indicator{display:flex;align-items:center;gap:6px;font-family:'Share Tech Mono',monospace;font-size:.6rem;color:var(--green);letter-spacing:.1em;text-transform:uppercase;}
.status-dot{width:6px;height:6px;background:var(--green);border-radius:50%;animation:blink 1.5s ease-in-out infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.clock{font-family:'Share Tech Mono',monospace;font-size:.7rem;color:var(--text2);letter-spacing:.1em;}
.user-pill{display:flex;align-items:center;gap:7px;background:var(--bg3);border:1px solid var(--border2);padding:4px 12px;cursor:pointer;transition:border-color .15s;}
.user-pill:hover{border-color:var(--accent);}
.user-pill-name{font-family:'Share Tech Mono',monospace;font-size:.65rem;color:var(--white);letter-spacing:.08em;}
.user-pill-role{font-family:'Share Tech Mono',monospace;font-size:.55rem;color:var(--text3);letter-spacing:.08em;}
.user-pill-dot{width:7px;height:7px;border-radius:50%;background:var(--green);}
.user-pill-dot.admin{background:var(--red);}

/* SEARCH BAR */
.global-search{display:flex;align-items:center;gap:8px;background:var(--bg3);border:1px solid var(--border2);padding:4px 12px;transition:border-color .15s;}
.global-search:focus-within{border-color:var(--accent);}
.global-search input{background:none;border:none;outline:none;color:var(--white);font-family:'Share Tech Mono',monospace;font-size:.68rem;width:180px;letter-spacing:.05em;}
.global-search input::placeholder{color:var(--text3);}
.global-search span{color:var(--text3);font-size:.75rem;}

/* CLASSIF BANNER */
.classif-banner{background:var(--red);text-align:center;padding:5px;font-family:'Share Tech Mono',monospace;font-size:.65rem;letter-spacing:.25em;font-weight:bold;text-transform:uppercase;color:#fff;animation:bannerpulse 4s ease-in-out infinite;}
@keyframes bannerpulse{0%,100%{background:var(--red)}50%{background:#9b2335}}

/* LAYOUT */
.layout{display:grid;grid-template-columns:230px 1fr;min-height:calc(100vh - 64px - 30px);}

/* SIDEBAR */
aside{background:var(--bg2);border-right:1px solid var(--border);padding:1.5rem 0;position:sticky;top:64px;height:calc(100vh - 64px);overflow-y:auto;}
.nav-section{margin-bottom:1.8rem;}
.nav-section-title{font-family:'Share Tech Mono',monospace;font-size:.58rem;letter-spacing:.2em;color:var(--accent);text-transform:uppercase;padding:0 1.2rem .5rem;border-bottom:1px solid var(--border);margin-bottom:.5rem;}
.nav-section-title.admin-section{color:var(--red);}
.nav-item{display:flex;align-items:center;gap:.6rem;padding:.5rem 1.2rem;cursor:pointer;font-size:.9rem;font-weight:500;letter-spacing:.04em;color:var(--text2);text-transform:uppercase;transition:all .15s;border-left:2px solid transparent;}
.nav-item:hover,.nav-item.active{color:var(--white);background:rgba(255,107,0,.06);border-left-color:var(--accent);}
.nav-item.admin-item:hover,.nav-item.admin-item.active{background:rgba(192,57,43,.06);border-left-color:var(--red);}
.nav-item .icon{font-size:.8rem;opacity:.7;}
.nav-badge{margin-left:auto;font-family:'Share Tech Mono',monospace;font-size:.55rem;padding:2px 5px;background:var(--red);color:#fff;border-radius:2px;}
.nav-badge.green{background:var(--green);color:#000;}
.admin-only{display:none;}
.admin-only.visible{display:block;}

/* MAIN */
main{padding:2rem 2.5rem;background:var(--bg);}
.page-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:2rem;padding-bottom:1.2rem;border-bottom:1px solid var(--border);}
.page-title{font-family:'Teko',sans-serif;font-size:2.2rem;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--white);line-height:1;}
.page-subtitle{font-family:'Share Tech Mono',monospace;font-size:.62rem;color:var(--text3);letter-spacing:.15em;margin-top:4px;text-transform:uppercase;}
.section{display:none;animation:fadein .3s ease;}
.section.active{display:block;}
@keyframes fadein{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* BUTTONS */
.btn{font-family:'Share Tech Mono',monospace;font-size:.65rem;letter-spacing:.12em;padding:8px 18px;text-transform:uppercase;border:1px solid var(--accent);color:var(--accent);background:rgba(255,107,0,.07);cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:6px;}
.btn:hover{background:var(--accent);color:#000;box-shadow:0 0 18px rgba(255,107,0,.4);}
.btn-danger{border-color:var(--red);color:var(--red);background:rgba(192,57,43,.07);}
.btn-danger:hover{background:var(--red);color:#fff;box-shadow:0 0 18px rgba(192,57,43,.4);}
.btn-green{border-color:var(--green);color:var(--green);background:rgba(0,200,83,.07);}
.btn-green:hover{background:var(--green);color:#000;box-shadow:0 0 18px rgba(0,200,83,.4);}
.btn-sm{padding:3px 10px;font-size:.58rem;}
.btn:disabled{opacity:.35;cursor:not-allowed;pointer-events:none;}

/* PANELS */
.panel{background:var(--surface);border:1px solid var(--border);margin-bottom:1.5rem;}
.panel-header{display:flex;align-items:center;justify-content:space-between;padding:.9rem 1.4rem;border-bottom:1px solid var(--border);background:var(--bg3);}
.panel-title{font-family:'Teko',sans-serif;font-size:1.1rem;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--white);}
.panel-actions{display:flex;gap:.6rem;align-items:center;}

/* STAT CARDS */
.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:2rem;}
.stat-card{background:var(--surface);border:1px solid var(--border);padding:1.2rem 1.4rem;position:relative;overflow:hidden;transition:border-color .2s;}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--accent);}
.stat-card.red::before{background:var(--red)}.stat-card.green::before{background:var(--green)}.stat-card.blue::before{background:var(--cyan)}
.stat-card:hover{border-color:var(--border2);}
.stat-label{font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:.15em;color:var(--text3);text-transform:uppercase;margin-bottom:.5rem;}
.stat-value{font-family:'Teko',sans-serif;font-size:2.4rem;font-weight:600;color:var(--white);line-height:1;}
.stat-delta{font-family:'Share Tech Mono',monospace;font-size:.6rem;margin-top:4px;letter-spacing:.08em;}
.stat-delta.up{color:var(--green)}.stat-delta.down{color:var(--red)}
.progress-bar{height:4px;background:var(--border);border-radius:2px;overflow:hidden;margin-top:6px;}
.progress-fill{height:100%;border-radius:2px;transition:width 1s ease;}

/* TABLE */
table{width:100%;border-collapse:collapse;}
thead tr{background:var(--bg3);}
th{font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;color:var(--text3);padding:.7rem 1.2rem;text-align:left;border-bottom:1px solid var(--border);white-space:nowrap;}
td{padding:.75rem 1.2rem;font-size:.9rem;font-weight:500;border-bottom:1px solid rgba(30,45,61,.5);vertical-align:middle;color:var(--text);}
tbody tr:hover{background:rgba(255,107,0,.03);}
tbody tr:last-child td{border-bottom:none;}
.td-actions{display:flex;gap:.4rem;}

/* TAGS */
.tag{font-family:'Share Tech Mono',monospace;font-size:.58rem;letter-spacing:.1em;padding:3px 7px;border-radius:2px;text-transform:uppercase;display:inline-block;white-space:nowrap;}
.tag-orange{background:rgba(255,107,0,.15);color:var(--accent);border:1px solid rgba(255,107,0,.3);}
.tag-red{background:rgba(192,57,43,.15);color:#e74c3c;border:1px solid rgba(192,57,43,.3);}
.tag-green{background:rgba(0,200,83,.1);color:var(--green);border:1px solid rgba(0,200,83,.3);}
.tag-blue{background:rgba(79,195,247,.1);color:var(--cyan);border:1px solid rgba(79,195,247,.3);}
.tag-yellow{background:rgba(255,214,0,.1);color:var(--yellow);border:1px solid rgba(255,214,0,.3);}
.tag-gray{background:rgba(100,120,140,.1);color:var(--text2);border:1px solid var(--border2);}
.tag-purple{background:rgba(142,68,173,.15);color:#c39bd3;border:1px solid rgba(142,68,173,.3);}

/* CLEARANCE */
.clr{font-family:'Share Tech Mono',monospace;font-size:.65rem;}
.clr-1{color:#ecf0f1}.clr-2{color:#3498db}.clr-3{color:#2ecc71}.clr-4{color:#e67e22}.clr-5{color:#e74c3c}
.id-code{font-family:'Share Tech Mono',monospace;font-size:.7rem;color:var(--text3);letter-spacing:.05em;}

/* FORM */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;padding:1.4rem;}
.form-group{display:flex;flex-direction:column;gap:5px;}
.form-group.full{grid-column:1/-1;}
label{font-family:'Share Tech Mono',monospace;font-size:.58rem;letter-spacing:.15em;color:var(--text3);text-transform:uppercase;}
input,select,textarea{background:var(--bg2);border:1px solid var(--border2);color:var(--text);font-family:'Rajdhani',sans-serif;font-size:.9rem;font-weight:500;padding:8px 12px;outline:none;transition:border-color .15s;-webkit-appearance:none;}
input:focus,select:focus,textarea:focus{border-color:var(--accent);box-shadow:0 0 0 2px rgba(255,107,0,.1);}
input:read-only{opacity:.5;cursor:not-allowed;}
textarea{resize:vertical;min-height:70px;}
select option{background:var(--bg2);}
.form-actions{display:flex;gap:.7rem;padding:1rem 1.4rem;border-top:1px solid var(--border);background:var(--bg3);}

/* ALERTS */
.alert{display:flex;gap:1rem;padding:1rem 1.2rem;border-left:3px solid;margin-bottom:1rem;background:var(--surface);font-size:.88rem;line-height:1.5;}
.alert-warn{border-color:var(--yellow);background:rgba(255,214,0,.04);}
.alert-info{border-color:var(--cyan);background:rgba(79,195,247,.04);}
.alert-error{border-color:var(--red);background:rgba(192,57,43,.04);}
.alert-icon{font-size:1.1rem;flex-shrink:0;margin-top:1px;}
.alert-text{color:var(--text2);}
.alert-text strong{color:var(--white);}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:500;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:var(--bg2);border:1px solid var(--border2);min-width:440px;max-width:620px;width:100%;animation:fadein .2s ease;max-height:90vh;overflow-y:auto;}
.modal-header{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.4rem;border-bottom:1px solid var(--border);background:var(--bg3);position:sticky;top:0;}
.modal-title{font-family:'Teko',sans-serif;font-size:1.2rem;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--white);}
.modal-close{background:none;border:none;color:var(--text3);cursor:pointer;font-size:1.2rem;line-height:1;}
.modal-close:hover{color:var(--white);}
.modal-body{padding:1.4rem;}

/* JOURNAL */
.journal-entry{display:flex;gap:1rem;padding:.75rem 1.2rem;border-bottom:1px solid rgba(30,45,61,.4);align-items:flex-start;}
.journal-entry:last-child{border-bottom:none;}
.journal-entry:hover{background:rgba(255,107,0,.02);}
.journal-time{font-family:'Share Tech Mono',monospace;font-size:.6rem;color:var(--text3);letter-spacing:.08em;white-space:nowrap;min-width:90px;padding-top:2px;}
.journal-icon{font-size:.85rem;min-width:20px;text-align:center;}
.journal-text{font-size:.88rem;color:var(--text2);line-height:1.4;}
.journal-text strong{color:var(--white);}

/* ADMIN PANEL */
.admin-banner{background:rgba(192,57,43,.08);border:1px solid rgba(192,57,43,.3);padding:.8rem 1.2rem;margin-bottom:1.5rem;display:flex;align-items:center;gap:.8rem;}
.admin-banner-icon{font-size:1rem;color:var(--red);}
.admin-banner-text{font-family:'Share Tech Mono',monospace;font-size:.65rem;color:var(--red);letter-spacing:.1em;text-transform:uppercase;}

/* ACCOUNT PANEL */
.account-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;}
.account-card{background:var(--surface);border:1px solid var(--border);padding:1.2rem;position:relative;overflow:hidden;}
.account-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.account-card.admin-card::before{background:var(--red);}
.account-card.user-card::before{background:var(--accent);}
.account-card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:.8rem;}
.account-card-name{font-family:'Teko',sans-serif;font-size:1.1rem;letter-spacing:.08em;color:var(--white);text-transform:uppercase;}
.account-card-id{font-family:'Share Tech Mono',monospace;font-size:.6rem;color:var(--text3);letter-spacing:.1em;margin-top:2px;}
.account-card-actions{display:flex;gap:.4rem;margin-top:.8rem;}

/* READONLY LOCKED */
.locked-notice{font-family:'Share Tech Mono',monospace;font-size:.62rem;color:var(--text3);letter-spacing:.1em;padding:.5rem .8rem;border:1px dashed var(--border2);text-align:center;text-transform:uppercase;}

/* FOOTER */
footer{background:var(--bg2);border-top:1px solid var(--border);padding:.8rem 2.5rem;font-family:'Share Tech Mono',monospace;font-size:.58rem;letter-spacing:.1em;color:var(--text3);text-transform:uppercase;display:flex;justify-content:space-between;align-items:center;}

/* TOAST */
.toast{position:fixed;bottom:2rem;right:2rem;background:var(--bg3);border:1px solid var(--accent);color:var(--white);font-family:'Share Tech Mono',monospace;font-size:.65rem;letter-spacing:.1em;padding:.8rem 1.2rem;z-index:9999;display:none;animation:fadein .3s ease;max-width:340px;}
.toast.show{display:flex;gap:.6rem;align-items:center;}
.toast.error{border-color:var(--red);}
.toast.success{border-color:var(--green);}
</style>
</head>
