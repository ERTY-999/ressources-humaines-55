<!-- ══════════════════════ APP ══════════════════════ -->
<header>
  <div class="header-left">
    <div class="scp-logo">
      <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="46" stroke="#ff6b00" stroke-width="4"/>
        <circle cx="50" cy="50" r="18" fill="none" stroke="#ff6b00" stroke-width="4"/>
        <line x1="50" y1="4" x2="50" y2="32" stroke="#ff6b00" stroke-width="4"/>
        <line x1="50" y1="68" x2="50" y2="96" stroke="#ff6b00" stroke-width="4"/>
        <line x1="4" y1="50" x2="32" y2="50" stroke="#ff6b00" stroke-width="4"/>
        <line x1="68" y1="50" x2="96" y2="50" stroke="#ff6b00" stroke-width="4"/>
        <circle cx="50" cy="50" r="6" fill="#ff6b00"/>
      </svg>
