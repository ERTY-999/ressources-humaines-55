function saveCompte(){
  const login=document.getElementById('c-login').value.trim();
  const pass=document.getElementById('c-pass').value;
  const name=document.getElementById('c-name').value.trim();
  const role=document.getElementById('c-role').value;
  if(!login||!pass||!name){showToast('Tous les champs requis','error');return;}
  if(pass.length<6){showToast('Mot de passe trop court (min 6)','error');return;}
  if(state.comptes.find(c=>c.login===login)){showToast('Identifiant déjà utilisé','error');return;}
  state.comptes.push({login,pass,name,role,createdAt:now(),lastLogin:null});
  addJournal('👥',`<strong>Nouveau compte créé</strong> : ${name} [${login}] — Rôle : ${role==='admin'?'Admin':'Utilisateur'}`);
  renderComptes();
  closeModal('modal-compte');
  showToast('Compte créé : '+login,'success');
}

function deleteCompte(i){
  const c=state.comptes[i];
  if(c.login==='admin'){showToast('Le compte admin système est protégé','error');return;}
  if(!confirm(`Supprimer le compte de ${c.name} (${c.login}) ?`)) return;
  state.comptes.splice(i,1);
  addJournal('🗑',`<strong>Compte supprimé</strong> : ${c.name} [${c.login}]`);
  renderComptes();
  showToast('Compte supprimé','error');
}

