<script>
// ══════════════ STATE ══════════════
let state = {
  agents: [], recrutements: [], sanctions: [], promotions: [],
  mutations: [], evaluations: [], journal: [], idCounter: 1,
  comptes: [
    { login:'admin',  pass:'scp-admin', name:'Administrateur',  role:'admin',  createdAt:'Système', lastLogin:null },
    { login:'rh-agent', pass:'rh2025', name:'Agent RH Dupont',  role:'user',   createdAt:'Système', lastLogin:null }
  ]
};
let currentUser = null;
let pendingRefusCallback = null;

// ══════════════ UTILS ══════════════
const DEPTS = ['Département Scientifique','Force d\'Intervention Mobile','Département Sécuritaire','Département de l\'I&ST','Département Médical','Département Administratif','Bureau du Comité d\'Ethique','Département de la Justice Interne','Département des Ressources Humaines'];
function genId(){ return 'RH-' + String(state.idCounter++).padStart(4,'0'); }
function now(){ const d=new Date(); return d.toLocaleDateString('fr-FR')+' '+d.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'}); }
function shortNow(){ return new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit',second:'2-digit'}); }
function genRef(p){ return p+'-'+Date.now().toString().slice(-6); }
const habLabels={1:'Niv.1',2:'Niv.2',3:'Niv.3',4:'Niv.4',5:'Niv.5'};
const habNames={1:'PUBLIC RESTREINT',2:'RESTREINT',3:'CONFIDENTIEL',4:'SECRET',5:'TOP SECRET'};
const habColors={1:'tag-gray',2:'tag-blue',3:'tag-green',4:'tag-orange',5:'tag-red'};
const statutColors={'Actif':'tag-green','Inactif':'tag-gray','Suspendu':'tag-red','Détaché':'tag-yellow','Décédé':'tag-purple'};
const gradeColors={'A':'tag-yellow','B':'tag-orange','C':'tag-red','D':'tag-red','E':'tag-red'};
const isAdmin = () => currentUser && currentUser.role === 'admin';

// ══════════════ CLOCK ══════════════
function updateClock(){
  const d=new Date();
  document.getElementById('clock').textContent=d.toLocaleTimeString('fr-FR')+' UTC';
  document.getElementById('dateDisplay').textContent=d.toLocaleDateString('fr-FR',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
}
setInterval(updateClock,1000); updateClock();

// ══════════════ LOGIN ══════════════
document.getElementById('login-pass').addEventListener('keydown',e=>{ if(e.key==='Enter') doLogin(); });
document.getElementById('login-user').addEventListener('keydown',e=>{ if(e.key==='Enter') doLogin(); });

function doLogin(){
  const u=document.getElementById('login-user').value.trim();
  const p=document.getElementById('login-pass').value;
  const compte=state.comptes.find(c=>c.login===u && c.pass===p);
  if(!compte){ document.getElementById('login-error').classList.add('show'); return; }
  document.getElementById('login-error').classList.remove('show');
  compte.lastLogin=now();
  currentUser=compte;
  document.getElementById('login-screen').classList.add('hidden');
  updateUserUI();
  addJournal('🔐',`<strong>Connexion</strong> : ${compte.name} [${compte.login}] — Rôle : ${compte.role==='admin'?'Administrateur':'Utilisateur RH'}`);
  showToast('Bienvenue, '+compte.name,'success');
}

function doLogout(){
  addJournal('🔓',`<strong>Déconnexion</strong> : ${currentUser.name} [${currentUser.login}]`);
  currentUser=null;
  document.getElementById('login-user').value='';
  document.getElementById('login-pass').value='';
  document.getElementById('login-screen').classList.remove('hidden');
  showSection('dashboard',document.querySelector('[onclick*=dashboard]'));
}

function updateUserUI(){
  const a=isAdmin();
  document.getElementById('user-pill-name').textContent=currentUser.name;
  document.getElementById('user-pill-role').textContent=a?'ADMINISTRATEUR':'UTILISATEUR RH';
  document.getElementById('user-dot').className='user-pill-dot'+(a?' admin':'');
  document.getElementById('header-badge').className='clearance-badge'+(a?' admin-badge':'');
  document.getElementById('header-badge').textContent=a?'ADMIN — ACCÈS TOTAL':'Niveau 3 — Confidentiel';
  const adminSection=document.getElementById('nav-admin-section');
  adminSection.className='nav-section admin-only'+(a?' visible':'');
  renderCompteInfo();
}

// ══════════════ ADMIN GUARD ══════════════
function requireAdmin(fn){
  if(!isAdmin()){ showToast('Accès refusé — Admin requis','error'); return; }
  fn();
}

// ══════════════ NAVIGATION ══════════════
function showSection(id,el){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('section-'+id).classList.add('active');
  if(el) el.classList.add('active');
  if(id==='stats') renderStats();
  if(id==='admin'){ if(!isAdmin()){showToast('Accès refusé','error');showSection('dashboard',document.querySelector('[onclick*=dashboard]'));return;} renderAdminPanel(); }
  if(id==='comptes'){ if(!isAdmin()){showToast('Accès refusé','error');showSection('dashboard',document.querySelector('[onclick*=dashboard]'));return;} renderComptes(); }
}

// ══════════════ TOAST ══════════════
function showToast(msg,type=''){
  const t=document.getElementById('toast');
  t.className='toast show '+type;
  t.innerHTML=(type==='success'?'✔ ':type==='error'?'✖ ':'◈ ')+msg;
  setTimeout(()=>t.className='toast',3200);
}

// ══════════════ MODAL ══════════════
function openModal(id){ document.getElementById(id).classList.add('open'); }
function closeModal(id){ document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.modal-overlay').forEach(m=>{
  m.addEventListener('click',e=>{ if(e.target===m) m.classList.remove('open'); });
});

// ══════════════ JOURNAL ══════════════
function addJournal(icon,text){
  const author = currentUser ? ` <span style="color:var(--text3);font-size:.82em;">[${currentUser.login}]</span>` : '';
  state.journal.unshift({time:shortNow(),date:now(),icon,text:text+author});
  renderJournal(); renderRecentActivity();
}

function renderJournal(){
  const el=document.getElementById('journal-list');
  if(!state.journal.length){ el.innerHTML='<div style="padding:2rem;text-align:center;color:var(--text3);font-family:\'Share Tech Mono\',monospace;font-size:.7rem;letter-spacing:.1em;">JOURNAL VIDE</div>'; return; }
  el.innerHTML=state.journal.map(j=>`<div class="journal-entry"><span class="journal-time">${j.date}</span><span class="journal-icon">${j.icon}</span><span class="journal-text">${j.text}</span></div>`).join('');
}

function renderRecentActivity(){
  const el=document.getElementById('recent-activity');
  const recent=state.journal.slice(0,7);
  if(!recent.length){ el.innerHTML='<div style="padding:1.5rem;text-align:center;color:var(--text3);font-family:\'Share Tech Mono\',monospace;font-size:.7rem;">Aucune activité</div>'; return; }
  el.innerHTML=recent.map(j=>`<div class="journal-entry"><span class="journal-time">${j.date}</span><span class="journal-icon">${j.icon}</span><span class="journal-text">${j.text}</span></div>`).join('');
}

function clearJournal(){
  if(!confirm('Vider le journal d\'activité ?')) return;
  state.journal=[];
  renderJournal(); renderRecentActivity();
  showToast('Journal vidé','success');
}

// ══════════════ STATS DASHBOARD ══════════════
function updateStats(){
  const actifs=state.agents.filter(a=>a.statut==='Actif').length;
  document.getElementById('stat-actifs').textContent=actifs;
  document.getElementById('stat-actifs-delta').textContent=state.agents.length+' au total';
  document.getElementById('bar-actifs').style.width=Math.min(actifs*5,100)+'%';

  const sanctions=state.sanctions.filter(s=>s.statut==='En attente'||s.statut==='En traitement').length;
  document.getElementById('stat-sanctions').textContent=sanctions;
  document.getElementById('stat-sanctions-delta').className='stat-delta '+(sanctions>0?'down':'up');
  document.getElementById('stat-sanctions-delta').textContent=sanctions>0?'▲ Attention requise':'✔ Aucun dossier actif';
  document.getElementById('bar-sanctions').style.width=Math.min(sanctions*15,100)+'%';

  document.getElementById('stat-recrut').textContent=state.recrutements.length;
  document.getElementById('stat-recrut-delta').textContent=state.recrutements.length+' dossiers';
  document.getElementById('bar-recrut').style.width=Math.min(state.recrutements.length*10,100)+'%';

  const pending=pendingCount();
  document.getElementById('stat-pending').textContent=pending;
  document.getElementById('stat-pending-delta').textContent=pending>0?'En attente admin':'Aucune validation requise';
  document.getElementById('bar-pending').style.width=Math.min(pending*10,100)+'%';
  document.getElementById('badge-recrutement').textContent=state.recrutements.filter(r=>r.statut==='En attente').length;
  document.getElementById('badge-promotions').textContent=state.promotions.filter(p=>p.statut==='En attente').length;
  document.getElementById('badge-sanctions').textContent=state.sanctions.filter(s=>s.statut!=='Clos'&&s.statut!=='Refusé').length;
  document.getElementById('badge-pending').textContent=pending;
}

function pendingCount(){
  return state.recrutements.filter(r=>r.statut==='En attente').length
    + state.promotions.filter(p=>p.statut==='En attente').length
    + state.sanctions.filter(s=>s.statut==='En attente').length
    + state.mutations.filter(m=>m.statut==='En attente').length;
}

// ══════════════ AGENTS ══════════════
function renderAgents(){
  const tbody=document.getElementById('personnel-tbody');
  document.getElementById('personnel-count').textContent=state.agents.length+' agents';
  if(!state.agents.length){ tbody.innerHTML='<tr><td colspan="6" style="text-align:center;padding:2rem;color:var(--text3);font-family:\'Share Tech Mono\',monospace;font-size:.7rem;">AUCUN AGENT ENREGISTRÉ</td></tr>'; return; }
  tbody.innerHTML=state.agents.map((a,i)=>`
    <tr>
      <td class="id-code">${a.id}</td>
      <td><strong>${a.rang?a.rang+' ':''}${a.alias}</strong></td>
      <td>${a.dept}</td>
      <td><span class="tag ${habColors[a.hab]} clr">${habLabels[a.hab]} — ${habNames[a.hab]}</span></td>
      <td><span class="tag ${statutColors[a.statut]||'tag-gray'}">${a.statut}</span></td>
      <td><div class="td-actions">
        ${isAdmin()?`<button class="btn btn-sm" onclick="editAgent(${i})">✎ Éditer</button><button class="btn btn-danger btn-sm" onclick="deleteAgent(${i})">✗</button>`:'<span class="locked-notice">Lecture seule</span>'}
      </div></td>
    </tr>`).join('');
}

function openAgentModal(){
  document.getElementById('modal-agent-title').textContent='Ajouter un Agent';
  ['a-alias','a-id','a-rang'].forEach(id=>{document.getElementById(id).value='';});
  document.getElementById('a-dept').value='';
  document.getElementById('a-hab').value='3';
  document.getElementById('a-statut').value='Actif';
  document.getElementById('a-edit-index').value='';
  openModal('modal-agent');
}

function editAgent(i){
  if(!isAdmin()){showToast('Accès refusé','error');return;}
  const a=state.agents[i];
  document.getElementById('modal-agent-title').textContent='Modifier l\'Agent';
  document.getElementById('a-alias').value=a.alias;
  document.getElementById('a-id').value=a.id;
  document.getElementById('a-dept').value=a.dept;
  document.getElementById('a-hab').value=a.hab;
  document.getElementById('a-statut').value=a.statut;
  document.getElementById('a-rang').value=a.rang||'';
  document.getElementById('a-edit-index').value=i;
  openModal('modal-agent');
}

function saveAgent(){
  const alias=document.getElementById('a-alias').value.trim();
  const dept=document.getElementById('a-dept').value;
  const hab=parseInt(document.getElementById('a-hab').value);
  const statut=document.getElementById('a-statut').value;
  const rang=document.getElementById('a-rang').value.trim();
  const editIdx=document.getElementById('a-edit-index').value;
  if(!alias||!dept){showToast('Alias et département requis','error');return;}
  if(editIdx!==''){
    const a=state.agents[editIdx];
    a.alias=alias;a.dept=dept;a.hab=hab;a.statut=statut;a.rang=rang;
    addJournal('✎',`<strong>${a.id}</strong> — Dossier modifié : ${rang?rang+' ':''}${alias} [${dept}] — Statut : ${statut}`);
    showToast('Agent mis à jour','success');
  } else {
    const id=document.getElementById('a-id').value.trim()||genId();
    state.agents.push({id,alias,dept,hab,statut,rang,createdAt:now()});
