// Refus flow
function adminRefus(type,idx){
  pendingRefusCallback={type,idx};
  document.getElementById('motif-text').value='';
  openModal('modal-motif');
}

function confirmRefus(){
  const motif=document.getElementById('motif-text').value.trim();
  if(!motif){showToast('Motif requis','error');return;}
  const {type,idx}=pendingRefusCallback;
  if(type==='recrut'){
    const r=state.recrutements[idx]; r.statut='Refusé';
    addJournal('❌',`<strong>[ADMIN] Candidature refusée</strong> : ${r.alias} — ${motif}`);
    renderRecrutements();
  } else if(type==='promo'){
    const p=state.promotions[idx]; p.statut='Refusé';
    addJournal('❌',`<strong>[ADMIN] Promotion refusée</strong> : ${p.agentId} — ${motif}`);
    renderPromotions();
  } else if(type==='sanction'){
    const s=state.sanctions[idx]; s.statut='Refusé';
    addJournal('❌',`<strong>[ADMIN] Sanction refusée</strong> : ${s.agentId} — ${motif}`);
    renderSanctions();
  } else if(type==='mutation'){
    const m=state.mutations[idx]; m.statut='Refusé';
    addJournal('❌',`<strong>[ADMIN] Mutation refusée</strong> : ${m.agentId} → ${m.dest} — ${motif}`);
    renderMutations();
  }
  updateStats(); renderAdminPanel();
  closeModal('modal-motif');
  pendingRefusCallback=null;
  showToast('Refus enregistré','error');
}

